ARG DEBIAN_DIST=bookworm
FROM debian:$DEBIAN_DIST

ARG uncloud_VERSION
ARG DEBIAN_DIST
ARG BUILD_VERSION
ARG FULL_VERSION
ARG ARCH

RUN mkdir -p /output/usr/bin
RUN mkdir -p /output/DEBIAN
RUN mkdir -p /output/usr/share/doc/uncloud/

COPY build/${ARCH}/uncloud /output/usr/bin/uncloud

COPY packages/uncloud/output/DEBIAN/control /output/DEBIAN/
COPY packages/uncloud/output/changelog.Debian /output/usr/share/doc/uncloud/
COPY packages/uncloud/output/copyright /output/usr/share/doc/uncloud/

RUN sed -i "s/DIST/$DEBIAN_DIST/" /output/usr/share/doc/uncloud/changelog.Debian
RUN sed -i "s/BUILD_VERSION/$BUILD_VERSION/" /output/usr/share/doc/uncloud/changelog.Debian
RUN sed -i "s/uncloud_VERSION/$uncloud_VERSION/" /output/usr/share/doc/uncloud/changelog.Debian

RUN sed -i "s/DIST/$DEBIAN_DIST/" /output/DEBIAN/control
RUN sed -i "s/BUILD_VERSION/$BUILD_VERSION/" /output/DEBIAN/control
RUN sed -i "s/uncloud_VERSION/$uncloud_VERSION/" /output/DEBIAN/control
RUN sed -i "s/SUPPORTED_ARCHITECTURES/$ARCH/" /output/DEBIAN/control

RUN chmod 755 /output/usr/bin/uncloud
RUN dpkg-deb --build /output /uncloud_${FULL_VERSION}.deb
