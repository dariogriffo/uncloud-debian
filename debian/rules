#!/usr/bin/make -f
DEB_HOST_ARCH ?= $(shell dpkg-architecture -qDEB_HOST_ARCH)
UNCLOUD_VERSION := $(shell dpkg-parsechangelog -S Version | sed 's/[-~].*//')

%:
	dh $@

override_dh_auto_configure:

override_dh_auto_build:
	@arch="$(DEB_HOST_ARCH)"; \
	case "$$arch" in \
		amd64) RELEASE_ARCH="amd64" ;; \
		arm64) RELEASE_ARCH="arm64" ;; \
		*) echo "Unsupported architecture: $$arch"; exit 1 ;; \
	esac; \
	mkdir -p "build/$${RELEASE_ARCH}"; \
	echo "Downloading uc_linux_$${RELEASE_ARCH}.tar.gz for $(UNCLOUD_VERSION)..."; \
	wget -q "https://github.com/psviderski/uncloud/releases/download/v$(UNCLOUD_VERSION)/uc_linux_$${RELEASE_ARCH}.tar.gz"; \
	tar -xf "uc_linux_$${RELEASE_ARCH}.tar.gz" -C "build/$${RELEASE_ARCH}"; \
	rm -f "uc_linux_$${RELEASE_ARCH}.tar.gz"; \
	echo "$${RELEASE_ARCH}" > .uncloud_arch; \
	echo "Downloading uncloudd_linux_$${RELEASE_ARCH}.tar.gz for $(UNCLOUD_VERSION)..."; \
	wget -q "https://github.com/psviderski/uncloud/releases/download/v$(UNCLOUD_VERSION)/uncloudd_linux_$${RELEASE_ARCH}.tar.gz"; \
	tar -xf "uncloudd_linux_$${RELEASE_ARCH}.tar.gz" -C "build/$${RELEASE_ARCH}"; \
	rm -f "uncloudd_linux_$${RELEASE_ARCH}.tar.gz"

override_dh_auto_install:
	@RELEASE_ARCH=$$(cat .uncloud_arch); \
	install -D -m 755 "build/$${RELEASE_ARCH}/uc" debian/uncloud/usr/bin/uc; \
	install -D -m 755 "build/$${RELEASE_ARCH}/uncloudd" debian/uncloudd/usr/bin/uncloudd

override_dh_auto_test:

override_dh_auto_clean:
	@rm -rf build .uncloud_arch || true

override_dh_strip:

override_dh_shlibdeps:
